@model Diploma.Web.Controllers.AdminStatsDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="container-fluid bg-dark text-white min-vh-100 p-4">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="h3 mb-0">System Analytics</h1>
                <p class="text-muted small">Global infrastructure telemetry</p>
            </div>
            <div class="text-end">
                <span class="badge bg-primary">Admin Mode</span>
                <span class="badge bg-success ms-2">Systems Operational</span>
            </div>
        </div>
    </div>

    <!-- Key Metrics -->
    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card bg-secondary bg-opacity-10 border-secondary h-100 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted small text-uppercase fw-bold">Active Users</h6>
                    <div class="h2 mb-0">@Model.TotalUsers</div>
                    <small class="text-success">Total Registered</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-secondary bg-opacity-10 border-secondary h-100 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted small text-uppercase fw-bold">Global Documents</h6>
                    <div class="h2 mb-0">@Model.TotalDocuments</div>
                    <small class="text-info">Persisted Metadata</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-secondary bg-opacity-10 border-secondary h-100 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted small text-uppercase fw-bold">Vector Chunks</h6>
                    <div class="h2 mb-0">@Model.TotalChunks</div>
                    <small class="text-warning">Indexed in Qdrant</small>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card bg-secondary bg-opacity-10 border-secondary h-100 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted small text-uppercase fw-bold">Avg Density</h6>
                    <div class="h2 mb-0">@(Model.TotalDocuments > 0 ? Model.TotalChunks / Model.TotalDocuments : 0)</div>
                    <small class="text-muted">Chunks per Doc</small>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Activity Chart: Daily Uploads -->
        <div class="col-md-8">
            <div class="card bg-secondary bg-opacity-10 border-secondary shadow-sm">
                <div class="card-header bg-transparent border-secondary py-3">
                    <h5 class="mb-0 h6 fw-bold">Ingestion Velocity (Last 7 Days)</h5>
                </div>
                <div class="card-body">
                    <canvas id="activityChart" style="height: 300px;"></canvas>
                </div>
            </div>
        </div>

        <!-- Distribution Chart: File Types -->
        <div class="col-md-4">
            <div class="card bg-secondary bg-opacity-10 border-secondary shadow-sm h-100">
                <div class="card-header bg-transparent border-secondary py-3">
                    <h5 class="mb-0 h6 fw-bold">Knowledge Distribution</h5>
                </div>
                <div class="card-body d-flex align-items-center">
                    <canvas id="distributionChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- User Table -->
    <div class="row">
        <div class="col-12">
            <div class="card bg-secondary bg-opacity-10 border-secondary shadow-sm">
                <div class="card-header bg-transparent border-secondary py-3 d-flex justify-content-between align-items-center">
                    <h5 class="mb-0 h6 fw-bold">Storage Partitioning</h5>
                    <button class="btn btn-sm btn-outline-secondary" onclick="window.location.reload()">Refresh Data</button>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0 small">
                            <thead class="table-secondary">
                                <tr>
                                    <th class="ps-4">User Partition ID</th>
                                    <th class="text-end pe-4">Document Count</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var user in Model.DocumentsByUser)
                                {
                                    <tr>
                                        <td class="ps-4 font-monospace py-3">@user.UserId</td>
                                        <td class="text-end pe-4 py-3"><span class="badge bg-dark border border-secondary">@user.Count docs</span></td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // --- Chart Themes & Config ---
    const chartTheme = {
        grid: { color: 'rgba(255, 255, 255, 0.05)' },
        text: { color: '#94a3b8' },
        primary: '#4f46e5',
        secondary: '#10b981',
        warning: '#f59e0b'
    };

    // 1. Activity Chart (Line)
    const ctxActivity = document.getElementById('activityChart').getContext('2d');
    new Chart(ctxActivity, {
        type: 'line',
        data: {
            labels: @Json.Serialize(Model.UploadsHistory.Select(x => x.Date)),
            datasets: [{
                label: 'Documents Uploaded',
                data: @Json.Serialize(Model.UploadsHistory.Select(x => x.Count)),
                borderColor: chartTheme.primary,
                backgroundColor: 'rgba(79, 70, 229, 0.1)',
                fill: true,
                tension: 0.4,
                pointRadius: 4,
                pointBackgroundColor: chartTheme.primary
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                x: { grid: chartTheme.grid, ticks: { color: chartTheme.text.color } },
                y: { grid: chartTheme.grid, ticks: { color: chartTheme.text.color, stepSize: 1 }, beginAtZero: true }
            }
        }
    });

    // 2. Distribution Chart (Doughnut)
    const ctxDist = document.getElementById('distributionChart').getContext('2d');
    new Chart(ctxDist, {
        type: 'doughnut',
        data: {
            labels: @Json.Serialize(Model.TypeDistribution.Select(x => x.Extension)),
            datasets: [{
                data: @Json.Serialize(Model.TypeDistribution.Select(x => x.Count)),
                backgroundColor: [chartTheme.primary, chartTheme.secondary, chartTheme.warning, '#ef4444', '#8b5cf6'],
                borderWidth: 0,
                hoverOffset: 10
            }]
        },
        options: {
            responsive: true,
            cutout: '70%',
            plugins: {
                legend: { position: 'bottom', labels: { color: chartTheme.text.color, usePointStyle: true, padding: 20 } }
            }
        }
    });
</script>