@model Diploma.Web.Controllers.AdminStatsDto
@{
    ViewData["Title"] = "Admin Management Hub";
}

<div class="container-fluid bg-zinc-950 text-zinc-100 min-vh-100 p-8">
    <div class="max-w-7xl mx-auto space-y-12">
        <!-- Header -->
        <div class="flex items-center justify-between border-b border-zinc-800 pb-8">
            <div>
                <h1 class="text-3xl font-bold tracking-tight">Management Hub</h1>
                <p class="text-zinc-500 text-sm mt-1">Proactive infrastructure & tenant governance</p>
            </div>
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2 px-3 py-1.5 rounded-full bg-zinc-900 border border-zinc-800">
                    <div class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">Live Telemetry</span>
                </div>
            </div>
        </div>

        <!-- Infrastructure Health -->
        <section>
            <h3 class="text-[10px] uppercase font-bold text-zinc-500 tracking-[0.2em] mb-6">System Health Monitor</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                @{
                    var services = new[] { 
                        (Model.Health.Database, "database"), 
                        (Model.Health.VectorDb, "box"), 
                        (Model.Health.AiService, "cpu") 
                    };
                }
                @foreach (var (svc, icon) in services)
                {
                    <div class="p-6 rounded-2xl bg-zinc-900 border border-zinc-800 space-y-4">
                        <div class="flex items-center justify-between">
                            <div class="p-2 rounded-lg bg-zinc-950 border border-zinc-800">
                                <i data-lucide="@icon" class="w-5 h-5 text-zinc-400"></i>
                            </div>
                            <span class="px-2 py-1 rounded-md text-[10px] font-bold uppercase @(svc.IsHealthy ? "bg-emerald-500/10 text-emerald-500" : "bg-red-500/10 text-red-500")">
                                @(svc.IsHealthy ? "Operational" : "Degraded")
                            </span>
                        </div>
                        <div>
                            <h4 class="text-sm font-bold text-white">@svc.ServiceName</h4>
                            <p class="text-xs text-zinc-500 truncate mt-1">@svc.Message</p>
                        </div>
                        <div class="pt-2 flex items-center justify-between border-t border-zinc-800/50">
                            <span class="text-[9px] font-bold text-zinc-600 uppercase">Latency</span>
                            <span class="text-xs font-mono text-zinc-400">@svc.LatencyMs ms</span>
                        </div>
                    </div>
                }
            </div>
        </section>

        <!-- User Moderation & Tenant Governance -->
        <section>
            <h3 class="text-[10px] uppercase font-bold text-zinc-500 tracking-[0.2em] mb-6">Tenant Governance</h3>
            <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
                <table class="w-full text-left text-sm">
                    <thead class="bg-zinc-950 text-[10px] uppercase font-bold text-zinc-500 border-b border-zinc-800">
                        <tr>
                            <th class="px-6 py-4">Researcher Identity</th>
                            <th class="px-6 py-4">Storage Load</th>
                            <th class="px-6 py-4">Security Status</th>
                            <th class="px-6 py-4 text-right">Administrative Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-800">
                        @foreach (var user in Model.UserManagement)
                        {
                            <tr class="hover:bg-zinc-950/50 transition-colors group">
                                <td class="px-6 py-4">
                                    <div class="flex flex-col">
                                        <span class="text-zinc-200 font-medium">@user.Email</span>
                                        <span class="text-[10px] font-mono text-zinc-600">@user.UserId</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4">
                                    <span class="text-xs text-zinc-400">@user.DocumentCount documents</span>
                                </td>
                                <td class="px-6 py-4">
                                    @if (user.IsLockedOut)
                                    {
                                        <span class="px-2 py-0.5 rounded bg-red-500/10 text-red-500 text-[10px] font-bold uppercase">Deactivated</span>
                                    }
                                    else
                                    {
                                        <span class="px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-500 text-[10px] font-bold uppercase">Active</span>
                                    }
                                </td>
                                <td class="px-6 py-4 text-right">
                                    <div class="flex items-center justify-end gap-2">
                                        <form asp-action="ToggleUserStatus" method="post" class="inline">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <button type="submit" class="px-3 py-1.5 rounded-lg border border-zinc-800 text-[10px] font-bold uppercase hover:bg-zinc-800 transition-colors">
                                                @(user.IsLockedOut ? "Activate" : "Deactivate")
                                            </button>
                                        </form>
                                        <form asp-action="WipeUserVectors" method="post" class="inline">
                                            <input type="hidden" name="userId" value="@user.UserId" />
                                            <button type="button" onclick="window.confirmAction(this.parentElement, 'Purge Vector Memory', 'CRITICAL ACTION: Wipe all vector memory for this user? This action is irreversible.')" class="px-3 py-1.5 rounded-lg bg-red-500/10 text-red-500 border border-red-500/20 text-[10px] font-bold uppercase hover:bg-red-500/20 transition-colors">
                                                Purge Vectors
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>

        <!-- Ingestion Telemetry (Failed Tasks) -->
        <section>
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-[10px] uppercase font-bold text-zinc-500 tracking-[0.2em]">Ingestion Telemetry</h3>
                <span class="text-[9px] text-zinc-600 font-mono uppercase">Last 15 Incidents</span>
            </div>
            <div class="bg-zinc-900 border border-zinc-800 rounded-2xl overflow-hidden">
                <table class="w-full text-left text-sm">
                    <thead class="bg-zinc-950 text-[10px] uppercase font-bold text-zinc-500 border-b border-zinc-800">
                        <tr>
                            <th class="px-6 py-4">Timestamp</th>
                            <th class="px-6 py-4">Document</th>
                            <th class="px-6 py-4">Fault Description</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-zinc-800">
                        @if (Model.FailedIngestions.Any())
                        {
                            foreach (var fail in Model.FailedIngestions)
                            {
                                <tr class="hover:bg-zinc-950/50 transition-colors">
                                    <td class="px-6 py-4 text-xs font-mono text-zinc-500">@fail.Timestamp.ToString("HH:mm:ss")</td>
                                    <td class="px-6 py-4 text-xs font-medium text-zinc-300">@fail.FileName</td>
                                    <td class="px-6 py-4">
                                        <p class="text-[11px] text-red-400 font-mono leading-relaxed max-w-xl">@fail.ErrorMessage</p>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="3" class="px-6 py-12 text-center">
                                    <p class="text-[10px] text-zinc-600 uppercase tracking-widest font-bold">No recent ingestion faults detected</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    </div>
</div>