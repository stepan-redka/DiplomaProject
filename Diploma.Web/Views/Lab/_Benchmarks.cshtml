@model Diploma.Web.Models.AnalyticsViewModel

<div class="px-8 space-y-12 pb-24">
    <!-- Tier 1: Infrastructure Telemetry -->
    <section>
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Tier 01: Infrastructure Telemetry</h3>
            <span class="px-2 py-0.5 rounded bg-emerald-500/10 text-emerald-500 text-[9px] font-bold uppercase tracking-widest animate-pulse">Live Feed</span>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
            <!-- PostgreSQL -->
            <div class="p-5 rounded-2xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-3">
                <div class="flex items-center justify-between">
                    <i data-lucide="database" class="w-4 h-4 text-indigo-500"></i>
                    <div class="w-1.5 h-1.5 rounded-full @(Model.Health.Database.IsHealthy ? "bg-emerald-500" : "bg-red-500")"></div>
                </div>
                <div>
                    <p class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">PostgreSQL</p>
                    <p class="text-xs font-bold text-zinc-900 dark:text-white">@Model.Health.Database.LatencyMs ms Latency</p>
                </div>
            </div>
            <!-- Qdrant -->
            <div class="p-5 rounded-2xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-3">
                <div class="flex items-center justify-between">
                    <i data-lucide="box" class="w-4 h-4 text-indigo-500"></i>
                    <div class="w-1.5 h-1.5 rounded-full @(Model.Health.VectorDb.IsHealthy ? "bg-emerald-500" : "bg-red-500")"></div>
                </div>
                <div>
                    <p class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">Qdrant Vector</p>
                    <p class="text-xs font-bold text-zinc-900 dark:text-white">Indexed & Operational</p>
                </div>
            </div>
            <!-- Ollama -->
            <div class="p-5 rounded-2xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-3">
                <div class="flex items-center justify-between">
                    <i data-lucide="cpu" class="w-4 h-4 text-indigo-500"></i>
                    <div class="w-1.5 h-1.5 rounded-full @(Model.Health.AiService.IsHealthy ? "bg-emerald-500" : "bg-red-500")"></div>
                </div>
                <div>
                    <p class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">AI Provider (Ollama)</p>
                    <p class="text-xs font-bold text-zinc-900 dark:text-white">API Heartbeat OK</p>
                </div>
            </div>
            <!-- Host Server -->
            <div class="p-5 rounded-2xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-3">
                <div class="flex items-center justify-between">
                    <i data-lucide="server" class="w-4 h-4 text-indigo-500"></i>
                    <div class="text-[10px] font-mono text-zinc-400">@Model.Health.HostServer.CpuLoadPercentage% CPU</div>
                </div>
                <div>
                    <p class="text-[9px] font-bold text-zinc-400 uppercase tracking-widest">Host Node</p>
                    <p class="text-xs font-bold text-zinc-900 dark:text-white">@Model.Health.HostServer.RamUsedGb GB / @Model.Health.HostServer.RamTotalGb GB RAM</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Tier 2: Research Summary -->
    <section>
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Tier 02: Research Summary</h3>
            <div class="flex items-center gap-4">
                <a href="/Lab/ExportCsv" class="px-3 py-1.5 rounded-lg bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-[9px] font-bold uppercase tracking-widest text-zinc-600 dark:text-zinc-400 hover:text-indigo-600 transition-all flex items-center gap-2">
                    <i data-lucide="file-spreadsheet" class="w-3 h-3"></i> Export Research Data
                </a>
            </div>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="text-center space-y-1">
                <p class="text-4xl font-bold text-zinc-900 dark:text-white tracking-tighter">@Model.TotalSessions</p>
                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Total Active Sessions</p>
            </div>
            <div class="text-center space-y-1">
                <p class="text-4xl font-bold text-zinc-900 dark:text-white tracking-tighter">@Model.StorageUsedFormatted</p>
                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Registry Footprint</p>
            </div>
            <div class="text-center space-y-1">
                <div class="flex items-end justify-center gap-2">
                    <p class="text-4xl font-bold text-zinc-900 dark:text-white tracking-tighter">@Model.StorageUsedPercentage%</p>
                    <div class="w-16 h-1 bg-zinc-100 dark:bg-zinc-800 rounded-full mb-3 overflow-hidden">
                        <div class="h-full bg-indigo-500" style="width: @Model.StorageUsedPercentage%"></div>
                    </div>
                </div>
                <p class="text-[10px] font-bold text-zinc-400 uppercase tracking-widest">Registry Utilization (1GB Quota)</p>
            </div>
        </div>
    </section>

    <!-- Tier 3: Scientific Insights -->
    <section class="space-y-8">
        <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Tier 03: Scientific Insights</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <!-- Chart A: Model Latency -->
            <div class="p-6 rounded-3xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-4">
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Model Latency Comparison (ms)</p>
                <div class="h-48">
                    <canvas id="chartLatency"></canvas>
                </div>
            </div>

            <!-- Chart B: Ingestion Efficiency -->
            <div class="p-6 rounded-3xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-4">
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Ingestion Efficiency (Size vs Time)</p>
                <div class="h-48">
                    <canvas id="chartIngestion"></canvas>
                </div>
            </div>

            <!-- Chart C: Semantic Precision -->
            <div class="p-6 rounded-3xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-4">
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Semantic Precision Trend (Max Score)</p>
                <div class="h-48">
                    <canvas id="chartPrecision"></canvas>
                </div>
            </div>

            <!-- Chart D: Generation Throughput -->
            <div class="p-6 rounded-3xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-4">
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Generation Throughput (Tokens/Sec)</p>
                <div class="h-48">
                    <canvas id="chartThroughput"></canvas>
                </div>
            </div>

            <!-- Chart E: Math-to-Human Correlation -->
            <div class="p-6 rounded-3xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-4">
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Confidence-Effectiveness Map</p>
                <div class="h-48">
                    <canvas id="chartCorrelation"></canvas>
                </div>
            </div>

            <!-- Chart F: Knowledge Density -->
            <div class="p-6 rounded-3xl bg-zinc-50 dark:bg-zinc-900/50 border border-zinc-200 dark:border-zinc-800 space-y-4">
                <p class="text-[10px] font-bold text-zinc-500 uppercase tracking-widest">Knowledge Density (Chunks/Doc)</p>
                <div class="h-48">
                    <canvas id="chartDensity"></canvas>
                </div>
            </div>
        </div>
    </section>
</div>

<script>
    (function() {
        // Data Serialization
        const latencyData = @Html.Raw(Json.Serialize(Model.ModelLatency));
        const ingestionData = @Html.Raw(Json.Serialize(Model.IngestionEfficiency));
        const precisionData = @Html.Raw(Json.Serialize(Model.SemanticPrecision));
        const throughputData = @Html.Raw(Json.Serialize(Model.GenerationThroughput));
        const correlationData = @Html.Raw(Json.Serialize(Model.MathHumanCorrelation));
        const densityData = @Html.Raw(Json.Serialize(Model.KnowledgeDensity));

        const chartOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
                y: { grid: { color: 'rgba(0,0,0,0.03)' }, ticks: { font: { size: 9 } } },
                x: { grid: { display: false }, ticks: { font: { size: 9 } } }
            }
        };

        // Chart A: Latency (Bar)
        new Chart(document.getElementById('chartLatency'), {
            type: 'bar',
            data: {
                labels: latencyData.map(d => d.modelName),
                datasets: [{
                    data: latencyData.map(d => d.averageLatencyMs),
                    backgroundColor: '#6366f1',
                    borderRadius: 8
                }]
            },
            options: chartOptions
        });

        // Chart B: Ingestion (Scatter)
        new Chart(document.getElementById('chartIngestion'), {
            type: 'scatter',
            data: {
                datasets: [{
                    label: 'Efficiency',
                    data: ingestionData.map(d => ({ x: d.fileSizeBytes / 1024, y: d.processingTimeMs })),
                    backgroundColor: '#8b5cf6'
                }]
            },
            options: {
                ...chartOptions,
                scales: {
                    x: { title: { display: true, text: 'Size (KB)', font: { size: 8 } } },
                    y: { title: { display: true, text: 'Time (ms)', font: { size: 8 } } }
                }
            }
        });

        // Chart C: Precision (Line)
        new Chart(document.getElementById('chartPrecision'), {
            type: 'line',
            data: {
                labels: precisionData.map((_, i) => i + 1),
                datasets: [{
                    data: precisionData.map(d => d.maxScore),
                    borderColor: '#10b981',
                    backgroundColor: 'rgba(16, 185, 129, 0.1)',
                    fill: true,
                    tension: 0.4
                }]
            },
            options: chartOptions
        });

        // Chart D: Throughput (Bar)
        new Chart(document.getElementById('chartThroughput'), {
            type: 'bar',
            data: {
                labels: throughputData.map(d => d.modelName),
                datasets: [{
                    data: throughputData.map(d => d.tokensPerSec),
                    backgroundColor: '#f59e0b',
                    borderRadius: 8
                }]
            },
            options: chartOptions
        });

        // Chart E: Correlation (Bubble)
        new Chart(document.getElementById('chartCorrelation'), {
            type: 'bubble',
            data: {
                datasets: [{
                    data: correlationData.map(d => ({ x: d.similarityScore, y: d.userEffectiveness, r: 6 })),
                    backgroundColor: 'rgba(99, 102, 241, 0.5)'
                }]
            },
            options: {
                ...chartOptions,
                scales: {
                    x: { min: 0.5, max: 1.0, title: { display: true, text: 'Confidence', font: { size: 8 } } },
                    y: { min: 0, max: 2, ticks: { stepSize: 1 }, title: { display: true, text: 'Feedback', font: { size: 8 } } }
                }
            }
        });

        // Chart F: Density (Doughnut - as TreeMap is complex for standard Chart.js)
        new Chart(document.getElementById('chartDensity'), {
            type: 'doughnut',
            data: {
                labels: densityData.map(d => d.documentName),
                datasets: [{
                    data: densityData.map(d => d.chunkCount),
                    backgroundColor: ['#6366f1', '#8b5cf6', '#ec4899', '#f43f5e', '#f59e0b', '#10b981'],
                    borderWidth: 0
                }]
            },
            options: {
                ...chartOptions,
                cutout: '70%',
                plugins: { legend: { display: false } }
            }
        });
    })();
</script>
