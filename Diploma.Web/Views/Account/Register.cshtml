@model Diploma.Web.Models.Account.RegisterViewModel
@{
    ViewData["Title"] = "Register";
}

<div class="min-h-screen flex items-center justify-center p-4 bg-zinc-50 dark:bg-zinc-950 transition-colors duration-300">
    <div class="w-full max-w-md space-y-8 fade-in">
        <div class="text-center">
            <div class="w-12 h-12 bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-lg flex items-center justify-center mx-auto mb-6 shadow-sm dark:shadow-[0_0_20px_rgba(255,255,255,0.05)]">
                <i data-lucide="user-plus" class="w-6 h-6 text-zinc-900 dark:text-white"></i>
            </div>
            <h2 class="text-2xl font-bold tracking-tight text-zinc-900 dark:text-white">Establish Identity</h2>
            <p class="mt-2 text-sm text-zinc-500 tracking-tight font-medium">Join the research network</p>
        </div>

        <div class="bg-white dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-8 shadow-xl dark:shadow-2xl relative">
            <div class="absolute inset-0 bg-gradient-to-b from-zinc-500/[0.02] dark:from-white/[0.02] to-transparent pointer-events-none rounded-2xl"></div>
            
            <form asp-controller="Account" asp-action="Register" method="post" class="space-y-6 relative z-10">
                <div asp-validation-summary="All" class="text-red-500 text-[10px] font-bold uppercase tracking-widest list-none"></div>
                
                <div class="space-y-2">
                    <label asp-for="Email" class="text-[10px] uppercase font-bold text-zinc-400 dark:text-zinc-500 tracking-widest ml-1"></label>
                    <input asp-for="Email" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl px-4 py-3.5 text-sm text-zinc-900 dark:text-white focus:outline-none focus:border-indigo-500 dark:focus:border-zinc-500 transition-colors placeholder:text-zinc-300 dark:placeholder:text-zinc-800" placeholder="name@example.com" />
                    <span asp-validation-for="Email" class="text-red-500 text-[9px] font-bold uppercase tracking-tighter"></span>
                </div>
                
                <div class="space-y-2">
                    <label asp-for="Password" class="text-[10px] uppercase font-bold text-zinc-400 dark:text-zinc-500 tracking-widest ml-1"></label>
                    <input asp-for="Password" type="password" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl px-4 py-3.5 text-sm text-zinc-900 dark:text-white focus:outline-none focus:border-indigo-500 dark:focus:border-zinc-500 transition-colors placeholder:text-zinc-300 dark:placeholder:text-zinc-800" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-red-500 text-[9px] font-bold uppercase tracking-tighter"></span>
                </div>

                <div class="space-y-2">
                    <label asp-for="ConfirmPassword" class="text-[10px] uppercase font-bold text-zinc-400 dark:text-zinc-500 tracking-widest ml-1"></label>
                    <input asp-for="ConfirmPassword" type="password" class="w-full bg-zinc-50 dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-800 rounded-xl px-4 py-3.5 text-sm text-zinc-900 dark:text-white focus:outline-none focus:border-indigo-500 dark:focus:border-zinc-500 transition-colors placeholder:text-zinc-300 dark:placeholder:text-zinc-800" placeholder="••••••••" />
                    <span asp-validation-for="ConfirmPassword" class="text-red-500 text-[9px] font-bold uppercase tracking-tighter"></span>
                </div>
                
                <button type="submit" class="w-full bg-indigo-600 dark:bg-white hover:bg-indigo-700 dark:hover:bg-zinc-200 text-white dark:text-black font-bold text-xs uppercase tracking-[0.15em] py-4 rounded-xl transition-all shadow-lg active:scale-[0.98]">
                    Create Account
                </button>
            </form>
        </div>

        <p class="text-center text-[11px] text-zinc-400 dark:text-zinc-600 uppercase tracking-widest font-bold">
            Already established? 
            <a asp-action="Login" class="text-zinc-900 dark:text-zinc-300 hover:text-indigo-600 dark:hover:text-white transition-colors underline underline-offset-4">Log in here</a>
        </p>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}