@using Diploma.Application.DTOs
@using Diploma.Application.Interfaces
@model Diploma.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "Research Workspace";
    var isAuthenticated = Model.IsAuthenticated;
}

<!-- External Scientific Rendering -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css">
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<div class="flex h-screen w-full overflow-hidden bg-white dark:bg-zinc-950 text-zinc-600 dark:text-zinc-300 transition-colors duration-300">
    <!-- Pane 1: Navigation Sidebar (280px) -->
    <partial name="_Sidebar" model="Model.Sidebar" />

    <!-- Pane 2: Main Research Workspace (Elastic) -->
    <main class="flex-1 flex flex-col bg-white dark:bg-zinc-950 relative min-w-0" id="mainWorkspace" data-session-id="@Model.ActiveSessionId">
        <header class="h-16 border-b border-zinc-100 dark:border-zinc-900 flex items-center justify-between px-8 bg-white/80 dark:bg-zinc-950/80 backdrop-blur-xl z-20">
            <div class="flex items-center gap-6">
                <button id="toggleSidebar" class="p-2 -ml-2 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 text-zinc-400 dark:text-zinc-600 transition-all" title="Toggle Sidebar">
                    <i data-lucide="panel-left" class="w-5 h-5"></i>
                </button>
                <div class="flex items-center gap-2">
                    <div class="w-2 h-2 rounded-full @(isAuthenticated ? "bg-emerald-500 animate-pulse" : "bg-zinc-300 dark:bg-zinc-700")"></div>
                    <span class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400 dark:text-zinc-500">
                        @(isAuthenticated ? "Secure Environment" : "Public Sandbox")
                    </span>
                </div>
            </div>
            <div class="flex items-center gap-2">
                @if (isAuthenticated)
                {
                    <button id="exportBtn" onclick="window.ui.handleExport()" class="flex items-center gap-2 h-8 px-3 rounded-xl bg-zinc-50 dark:bg-zinc-900 border border-zinc-200 dark:border-zinc-800 text-[8px] font-bold uppercase tracking-widest text-zinc-500 dark:text-400 hover:text-zinc-900 dark:hover:text-white transition-all opacity-50 pointer-events-none" title="Active session required for export">
                        <i data-lucide="download" class="w-4 h-4"></i>
                        <span>Export Findings</span>
                    </button>
                    <div class="h-4 w-px bg-zinc-200 dark:border-zinc-800 mx-1"></div>
                }

                
                <button onclick="window.themeManager.toggle()" class="p-1.5 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 text-zinc-400 dark:text-zinc-600 transition-all" title="Toggle Theme">
                    <i data-lucide="sun" class="w-5 h-5 theme-sun"></i>
                    <i data-lucide="moon" class="w-5 h-5 theme-moon hidden"></i>
                </button>

                <button id="toggleInspector" class="p-1.5 rounded-lg hover:bg-zinc-200 dark:hover:bg-zinc-800 text-zinc-400 dark:text-zinc-600 transition-all" title="Source Inspector">
                    <i data-lucide="library" class="w-5 h-5"></i>
                </button>
            </div>
        </header>

        <!-- Optimized Research Feed -->
        <div id="chatWindow" class="flex-1 overflow-y-auto px-4 py-12 space-y-16 scroll-smooth">
            <!-- JS will inject professional markdown messages here -->
        </div>

        <!-- Research Command Center -->
        <div class="p-8 border-t border-zinc-100/30 dark:border-zinc-900/30">
            <div class="max-w-2xl mx-auto">
                <div class="relative group bg-zinc-50/50 dark:bg-zinc-900/40 border border-zinc-200 dark:border-zinc-800 rounded-2xl p-2 transition-all focus-within:border-zinc-300 dark:focus-within:border-zinc-700 focus-within:bg-white dark:focus-within:bg-zinc-900/60 shadow-xl dark:shadow-2xl">
                    <div id="loadingIndicator" class="hidden absolute inset-0 bg-white/90 dark:bg-zinc-950/90 backdrop-blur-sm z-10 flex items-center justify-center rounded-2xl">
                         <div class="flex flex-col items-center gap-4">
                            <div class="flex gap-1">
                                <div class="w-1 h-4 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                                <div class="w-1 h-4 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                                <div class="w-1 h-4 bg-indigo-500 rounded-full animate-bounce" style="animation-delay: 0.3s"></div>
                            </div>
                            <span class="text-[9px] font-bold uppercase tracking-[0.4em] text-zinc-400 dark:text-zinc-500">Synthesizing Repository Knowledge</span>
                        </div>
                    </div>
                    <div class="flex items-end gap-2">
                        <textarea id="chatInput" rows="1" placeholder="Search knowledge registry..." 
                                  class="flex-1 bg-transparent border-none text-zinc-900 dark:text-zinc-100 text-sm px-4 py-3 focus:outline-none focus:ring-0 placeholder:text-zinc-300 dark:placeholder:text-zinc-700 resize-none min-h-[48px]"></textarea>
                        <button id="sendBtn" class="mb-1 p-3 bg-indigo-600 hover:bg-indigo-500 text-white rounded-xl transition-all disabled:opacity-30 shadow-lg shadow-indigo-500/10">
                            <i data-lucide="send-horizontal" class="w-4 h-4"></i>
                        </button>
                    </div>
                </div>
                <div class="mt-4 flex items-center justify-center gap-12 text-xs font-bold uppercase tracking-widest text-zinc-400 dark:text-zinc-600">
                    <div class="flex items-center gap-4">
                        <i data-lucide="cpu" class="w-4 h-4"></i>
                        <select id="modelSelector" class="bg-transparent border-none p-0 text-xs text-zinc-400 dark:text-zinc-500 focus:outline-none hover:text-zinc-900 dark:hover:text-zinc-300 transition-colors uppercase font-bold tracking-widest cursor-pointer">
                            <option value="llama3.1">Llama 3.1 (8B)</option>
                            <option value="qwen2.5:7b">Qwen 2.5 (7B)</option>
                            <option value="phi3.5">Phi-3.5 (Mini)</option>
                        </select>
                    </div>
                    <div class="flex items-center gap-4">
                        <i data-lucide="layers" class="w-4 h-4"></i>
                        <div class="flex items-center gap-3">
                            <input type="range" min="1" max="10" step="1" id="topKRange" value="3" class="w-20 h-1 bg-zinc-200 dark:bg-zinc-800 rounded-lg appearance-none cursor-pointer accent-indigo-500">
                            <span id="topKValue" class="text-zinc-400 dark:text-zinc-500 font-mono w-4">3</span>
                        </div>
                    </div>
                    <div class="flex items-center gap-4">
                         <label class="relative inline-flex items-center cursor-pointer">
                            <input type="checkbox" id="researchModeToggle" class="sr-only peer">
                            <div class="w-8 h-4 bg-zinc-200 dark:bg-zinc-800 rounded-full peer peer-checked:bg-indigo-500 peer-checked:after:translate-x-4 after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-zinc-400 dark:after:bg-zinc-400 after:rounded-full after:h-3 after:w-3 after:transition-all"></div>
                         </label>
                         <span class="text-zinc-400 dark:text-zinc-600">Research Mode</span>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Pane 3: Source Inspector (Toggleable, 400px) -->
    <aside id="sourceInspector" class="hidden w-[400px] bg-white dark:bg-zinc-950 border-l border-zinc-100 dark:border-zinc-900 flex flex-col shrink-0 z-30 slide-in">
        <div class="p-6 border-b border-zinc-100 dark:border-zinc-900 flex items-center justify-between">
            <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Source Inspector</h3>
            <button id="closeInspector" class="text-zinc-400 hover:text-zinc-900 dark:hover:text-white transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <div id="inspectorContent" class="flex-1 overflow-y-auto p-6 space-y-8">
            <div class="h-full flex flex-col items-center justify-center text-center space-y-4 opacity-30">
                <i data-lucide="file-search" class="w-12 h-12 text-zinc-900 dark:text-white"></i>
                <p class="text-[10px] uppercase tracking-widest leading-relaxed text-zinc-900 dark:text-white">Select a citation badge to<br/>inspect verified evidence</p>
            </div>
        </div>
    </aside>
</div>

<!-- Modal Overlays preserved but updated to zinc theme -->
<div id="upsellModal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-white/80 dark:bg-black/95 backdrop-blur-xl"></div>
    <div class="relative w-full max-w-md bg-white dark:bg-zinc-950 border border-zinc-200 dark:border-zinc-900 rounded-3xl p-12 text-center space-y-8 shadow-2xl">
        <div class="w-16 h-16 bg-indigo-600/10 border border-indigo-500/20 rounded-2xl flex items-center justify-center mx-auto rotate-6 shadow-xl">
            <i data-lucide="database-zap" class="w-8 h-8 text-indigo-600 dark:text-indigo-400"></i>
        </div>
        <h2 class="text-2xl font-bold text-zinc-900 dark:text-white tracking-tight">Identity Required</h2>
        <p class="text-sm text-zinc-500 leading-relaxed">Establishing a researcher profile is mandatory for private indexing, multi-session persistence, and structured findings export.</p>
        <div class="space-y-3">
            <a href="/Account/Register" class="block w-full py-4 bg-indigo-600 text-white text-xs font-bold uppercase tracking-widest rounded-xl hover:bg-indigo-500 transition-all shadow-lg shadow-indigo-500/20">Establish Identity</a>
            <button onclick="document.getElementById('upsellModal').classList.add('hidden')" class="text-[9px] text-zinc-400 dark:text-zinc-600 hover:text-zinc-900 dark:hover:text-white uppercase font-bold tracking-widest transition-colors">Continue as Guest</button>
        </div>
    </div>
</div>

@section Scripts {
    <script type="module" src="/js/RagClient.js"></script>
    <script type="module" src="/js/RagUI.js"></script>
}
