@using Diploma.Application.DTOs
@using Diploma.Application.Interfaces
@model Diploma.Web.Models.DashboardViewModel
@{
    ViewData["Title"] = "RAG Dashboard";
    var isAuthenticated = Model.IsAuthenticated;
}

<div class="flex h-full w-full overflow-hidden bg-zinc-950">
    <!-- Sidebar: Knowledge Management -->
    <aside class="w-72 bg-zinc-950 border-r border-zinc-800 flex flex-col shrink-0">
        <div class="p-6 flex items-center gap-3">
            <div class="w-8 h-8 bg-white rounded flex items-center justify-center">
                <i data-lucide="bot" class="w-5 h-5 text-black"></i>
            </div>
            <span class="font-bold text-lg tracking-tight text-white">RagSystem</span>
        </div>

        @if (isAuthenticated)
        {
            <div class="px-6 py-2">
                 <div class="flex items-center justify-between mb-2">
                    <span class="text-[10px] uppercase font-bold text-zinc-500 tracking-widest">Researcher</span>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="text-zinc-500 hover:text-zinc-100 transition-colors" title="Logout">
                            <i data-lucide="log-out" class="w-3.5 h-3.5"></i>
                        </button>
                    </form>
                 </div>
                 <div class="flex items-center gap-2">
                    <div class="w-6 h-6 rounded-full bg-zinc-800 flex items-center justify-center text-[10px] font-bold text-zinc-100">
                        @(User.Identity?.Name?.Length > 0 ? User.Identity.Name.Substring(0, 1).ToUpper() : "R")
                    </div>
                    <span class="text-xs font-medium text-zinc-300 truncate">@User.Identity?.Name</span>
                 </div>
            </div>
        }
        else
        {
            <div class="px-6 py-2">
                 <a href="/Account/Login" class="flex items-center gap-3 p-3 rounded-lg border border-dashed border-zinc-800 hover:border-zinc-400 hover:bg-zinc-900/50 transition-all group">
                    <div class="w-8 h-8 rounded-full bg-zinc-900 border border-zinc-800 flex items-center justify-center text-zinc-500 group-hover:text-white transition-colors">
                        <i data-lucide="user-plus" class="w-4 h-4"></i>
                    </div>
                    <div class="flex flex-col">
                        <span class="text-[10px] font-bold text-white uppercase tracking-tighter">Upgrade Access</span>
                        <span class="text-[9px] text-zinc-500">Unlock private data silos</span>
                    </div>
                 </a>
            </div>
        }

        <nav class="flex-1 px-4 py-6 overflow-y-auto space-y-8">
            <!-- Minimalist Stats -->
            <div>
                <h3 class="px-2 text-[10px] uppercase font-bold text-zinc-500 tracking-widest mb-4">Research Analytics</h3>
                <div class="grid grid-cols-2 gap-2 px-2">
                    <div class="p-3 rounded-xl bg-zinc-900/50 border border-zinc-800">
                        <span class="block text-[9px] text-zinc-500 uppercase font-bold mb-1">Index</span>
                        <span class="text-lg font-bold text-white leading-none">@Model.TotalDocuments</span>
                    </div>
                    <div class="p-3 rounded-xl bg-zinc-900/50 border border-zinc-800">
                        <span class="block text-[9px] text-zinc-500 uppercase font-bold mb-1">Queries</span>
                        <span class="text-lg font-bold text-white leading-none">@Model.TotalQueries</span>
                    </div>
                    <div class="p-3 rounded-xl bg-zinc-900/50 border border-zinc-800">
                        <span class="block text-[9px] text-zinc-500 uppercase font-bold mb-1">Storage</span>
                        <span class="text-xs font-bold text-white leading-none">@Model.StorageUsedFormatted</span>
                    </div>
                    <div class="p-3 rounded-xl bg-zinc-900/50 border border-zinc-800">
                        <span class="block text-[9px] text-zinc-500 uppercase font-bold mb-1">Chunks</span>
                        <span class="text-lg font-bold text-white leading-none">@Model.TotalChunks</span>
                    </div>
                </div>
            </div>

            <div>
                <div class="flex items-center justify-between mb-4">
                    <h3 class="px-2 text-[10px] uppercase font-bold text-zinc-500 tracking-widest">Source Registry</h3>
                    @if(!isAuthenticated)
                    {
                        <span class="px-1.5 py-0.5 rounded-full bg-zinc-800 text-[8px] font-bold text-zinc-400 uppercase tracking-tighter">Demo</span>
                    }
                </div>
                <div id="documentList" class="space-y-1">
                    @if (Model.Documents != null && Model.Documents.Any())
                    {
                        foreach (var doc in Model.Documents)
                        {
                            <div class="group flex items-center justify-between px-2 py-2 rounded-md hover:bg-zinc-900 transition-all cursor-pointer border border-transparent hover:border-zinc-800" title="Created: @doc.CreatedAt">
                                <div class="flex items-center gap-2 overflow-hidden">
                                    <i data-lucide="file-text" class="w-4 h-4 text-zinc-500 shrink-0"></i>
                                    <span class="text-xs text-zinc-400 truncate group-hover:text-zinc-200">@doc.FileName</span>
                                </div>
                                <span class="text-[10px] font-mono text-zinc-600">@doc.ChunkCount</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="px-2 py-8 text-center">
                            <i data-lucide="database-zap" class="w-8 h-8 text-zinc-800 mx-auto mb-2"></i>
                            <p class="text-[10px] text-zinc-600 uppercase tracking-tighter">Registry Empty</p>
                        </div>
                    }
                </div>
            </div>
        </nav>

        <div class="p-4 border-t border-zinc-800 space-y-2">
            @if (isAuthenticated)
            {
                <form id="uploadForm" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <label class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-zinc-100 hover:bg-zinc-200 text-zinc-950 text-xs font-bold rounded-lg cursor-pointer transition-all">
                        <i data-lucide="upload-cloud" class="w-4 h-4"></i>
                        <span>INDEX KNOWLEDGE</span>
                        <input type="file" id="fileInput" name="files" hidden accept=".pdf,.docx,.md,.txt,.html" multiple />
                    </label>
                </form>
                <button id="pasteBtn" class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-transparent hover:bg-zinc-900 text-zinc-400 hover:text-zinc-100 text-xs font-bold rounded-lg border border-zinc-800 transition-all">
                    <i data-lucide="plus" class="w-4 h-4"></i>
                    <span>RAW STREAM</span>
                </button>
                <button id="clearBtn" class="w-full py-2 text-[9px] text-zinc-600 hover:text-red-400 transition-colors uppercase font-bold tracking-widest">
                    Purge Collection
                </button>
            }
            else
            {
                <button onclick="document.getElementById('upsellModal').classList.remove('hidden')" class="flex items-center justify-center gap-2 w-full px-4 py-2.5 bg-zinc-800 hover:bg-zinc-700 text-zinc-300 text-xs font-bold rounded-lg transition-all border border-zinc-700">
                    <i data-lucide="lock" class="w-4 h-4"></i>
                    <span>PRIVATE INDEX</span>
                </button>
                <p class="text-[9px] text-zinc-600 text-center uppercase tracking-widest py-2">Join to contribute knowledge</p>
            }
        </div>
    </aside>

    <!-- Main Workspace -->
    <main class="flex-1 flex flex-col bg-zinc-950 relative">
        <!-- Header / Stats Bar -->
        <header class="h-14 border-b border-zinc-800 flex items-center justify-between px-8 shrink-0 bg-zinc-950/50 backdrop-blur-md z-20">
            <div class="flex items-center gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-1.5 h-1.5 rounded-full bg-emerald-500 shadow-[0_0_8px_rgba(16,185,129,0.5)]"></div>
                    <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-500">
                        @(isAuthenticated ? "Private Environment" : "Public Sandbox")
                    </span>
                </div>
            </div>
            <div class="flex items-center gap-8">
                <div class="flex items-center gap-4">
                    <span class="text-[10px] uppercase font-bold text-zinc-500 tracking-widest">Retrieval Depth</span>
                    <input type="range" min="1" max="10" step="1" id="topKRange" value="3" class="w-24 h-1 bg-zinc-800 rounded-lg appearance-none cursor-pointer accent-white">
                    <span id="topKValue" class="text-xs font-mono font-bold text-white w-4">3</span>
                </div>
                
                @if (isAuthenticated)
                {
                    <div class="h-4 w-px bg-zinc-800"></div>
                    <a href="/Chat/ExportSession" class="flex items-center gap-2 text-[10px] font-bold uppercase tracking-widest text-zinc-400 hover:text-white transition-colors">
                        <i data-lucide="download" class="w-3.5 h-3.5"></i>
                        <span>Export Findings</span>
                    </a>
                }
            </div>
        </header>

        <!-- Chat Stream -->
        <div id="chatWindow" class="flex-1 overflow-y-auto px-4 py-12 space-y-12 scroll-smooth">
            <!-- Initial Welcome Message -->
            <div class="max-w-2xl mx-auto flex gap-6 fade-in">
                <div class="w-8 h-8 rounded bg-zinc-900 border border-zinc-800 flex items-center justify-center shrink-0">
                    <i data-lucide="sparkles" class="w-4 h-4 text-zinc-400"></i>
                </div>
                <div class="space-y-2">
                    <p class="text-sm leading-relaxed text-zinc-400">
                        Welcome to <span class="text-white font-semibold">RagSystem Research</span>. 
                        @if (isAuthenticated)
                        {
                            <span>Workspace established for <strong>@User.Identity?.Name</strong>. Your data is isolated and persistent.</span>
                        }
                        else
                        {
                            <span>You are in a <strong>Guest Sandbox</strong>. Interact with public sources below or sign up to establish a private research silo.</span>
                        }
                    </p>
                </div>
            </div>
        </div>

        <!-- Input Section -->
        <div class="p-8 shrink-0 pb-12">
            <div class="max-w-2xl mx-auto relative group">
                <div class="absolute -inset-1 bg-gradient-to-r from-zinc-800 to-zinc-700 rounded-2xl blur opacity-20 group-focus-within:opacity-40 transition duration-1000"></div>
                <div class="relative bg-zinc-900 border border-zinc-800 rounded-xl shadow-2xl overflow-hidden">
                    <div id="loadingIndicator" class="hidden absolute inset-0 bg-zinc-900/80 backdrop-blur-sm z-10 flex items-center justify-center">
                        <div class="flex items-center gap-3">
                            <div class="w-4 h-4 border-2 border-zinc-500 border-t-white rounded-full animate-spin"></div>
                            <span class="text-[10px] font-bold uppercase tracking-widest text-zinc-400">Synthesizing Findings</span>
                        </div>
                    </div>
                    
                    <div class="flex items-center p-2">
                        <!-- Research Mode Toggle -->
                        <div class="flex items-center gap-2 px-3 border-r border-zinc-800 mr-2 group/toggle">
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" id="researchModeToggle" class="sr-only peer" checked>
                                <div class="w-7 h-4 bg-zinc-800 peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-zinc-400 after:border-zinc-300 after:border after:rounded-full after:h-3 after:w-3 after:transition-all peer-checked:after:bg-white peer-checked:bg-indigo-600"></div>
                            </label>
                            <span class="text-[9px] font-bold uppercase tracking-tighter text-zinc-500 peer-checked:text-zinc-300 transition-colors select-none">Research</span>
                        </div>

                        <input type="text" id="chatInput" placeholder="Query the knowledge base..." autocomplete="off" 
                               class="flex-1 bg-transparent border-none text-zinc-100 text-sm px-4 py-3 focus:outline-none focus:ring-0 placeholder:text-zinc-600">
                        <button id="sendBtn" class="p-2 bg-white hover:bg-zinc-200 text-black rounded-lg transition-all disabled:opacity-50 group/btn">
                            <i data-lucide="arrow-up" class="w-4 h-4 group-hover/btn:-translate-y-0.5 transition-transform"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </main>
</div>

<!-- Modal Overlay (Paste) -->
<div id="pasteModal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-md"></div>
    <div class="relative w-full max-w-lg bg-zinc-950 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden fade-in">
        <div class="p-6 border-b border-zinc-800 flex items-center justify-between bg-zinc-900/50">
            <h3 class="text-[10px] font-bold uppercase tracking-[0.2em] text-zinc-400">Raw Stream Ingestion</h3>
            <button id="closePasteBtn" class="text-zinc-500 hover:text-white transition-colors">
                <i data-lucide="x" class="w-4 h-4"></i>
            </button>
        </div>
        <div class="p-8 space-y-6">
            <div>
                <label class="block text-[10px] uppercase font-bold text-zinc-500 mb-2 tracking-widest">Entry Identifier</label>
                <input type="text" id="manualDocName" placeholder="e.g. Theoretical Framework" 
                       class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-2.5 text-sm text-white focus:outline-none focus:border-zinc-500 transition-colors">
            </div>
            <div>
                <label class="block text-[10px] uppercase font-bold text-zinc-500 mb-2 tracking-widest">Knowledge Content</label>
                <textarea id="manualContent" rows="8" placeholder="Paste data for indexing..." 
                          class="w-full bg-zinc-900 border border-zinc-800 rounded-lg px-4 py-3 text-sm text-white focus:outline-none focus:border-zinc-500 transition-colors resize-none"></textarea>
            </div>
        </div>
        <div class="p-6 bg-zinc-900/30 border-t border-zinc-800 flex justify-end gap-3">
            <button id="cancelPasteBtn" class="px-4 py-2 text-xs font-bold uppercase tracking-widest text-zinc-500 hover:text-white transition-colors">Cancel</button>
            <button id="savePasteBtn" class="px-6 py-2.5 bg-white text-black text-xs font-bold uppercase tracking-widest rounded-lg hover:bg-zinc-200 transition-all">Commit Index</button>
        </div>
    </div>
</div>

<!-- Modal Overlay (Identity Upsell) -->
<div id="upsellModal" class="hidden fixed inset-0 z-50 flex items-center justify-center px-4">
    <div class="absolute inset-0 bg-black/90 backdrop-blur-md"></div>
    <div class="relative w-full max-w-md bg-zinc-950 border border-zinc-800 rounded-2xl shadow-2xl overflow-hidden fade-in">
        <div class="p-12 text-center space-y-6">
            <div class="w-16 h-16 bg-white rounded-2xl flex items-center justify-center mx-auto mb-4 rotate-3">
                <i data-lucide="shield-check" class="w-8 h-8 text-black"></i>
            </div>
            <h2 class="text-2xl font-bold text-white tracking-tight">Expand Research Limits</h2>
            <p class="text-sm text-zinc-400 leading-relaxed">
                Unlock private data silos, persistent history, and professional data export by establishing a researcher identity.
            </p>
            <div class="pt-4 space-y-3">
                <a href="/Account/Register" class="block w-full py-3 bg-white text-black text-sm font-bold uppercase tracking-widest rounded-xl hover:bg-zinc-200 transition-all">
                    Register Identity
                </a>
                <a href="/Account/Login" class="block w-full py-3 bg-transparent text-zinc-400 text-sm font-bold uppercase tracking-widest rounded-xl hover:bg-zinc-900 transition-all border border-zinc-800">
                    Sign In
                </a>
                <button onclick="document.getElementById('upsellModal').classList.add('hidden')" class="text-[10px] text-zinc-600 hover:text-zinc-400 uppercase font-bold tracking-widest transition-colors">
                    Continue Exploring
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="/js/chat.js" type="module"></script>
}
